# AI Linguistic Discourse Analyzer — Environment Variables
# Скопируйте в .env.local для локальной разработки
# В Vercel: Settings → Environment Variables

# LLM API-ключи (хотя бы один обязателен)
VITE_GROQ_API_KEY=
VITE_OPENAI_API_KEY=
VITE_GEMINI_API_KEY=

# Провайдер и модель по умолчанию (опционально)
VITE_DEFAULT_PROVIDER=groq
VITE_DEFAULT_MODEL=llama-3.3-70b-versatile
